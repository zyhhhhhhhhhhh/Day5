  <!-- 全局蓝色主题样式表 -->
  <property name="styleSheet">
   <string notr="true">/* 主窗口背景 */
QWidget#Widget {
        background-color: #f0f5ff;
}

/* 按钮样式 - 主蓝色按钮 */
QPushButton {
        background-color: #2d8cf0;
        color: white;
        border: none;
        border-radius: 6px;
        padding: 8px 16px;
        font-size: 14px;
        font-weight: 500;
}

/* 按钮悬停效果 */
QPushButton:hover {
        background-color: #409eff;
}

/* 按钮按下效果 */
QPushButton:pressed {
        background-color: #1b74d6;
}

/* 数字输入框样式 */
QDoubleSpinBox {
        background-color: white;
        border: 1px solid #c0d4f0;
        border-radius: 4px;
        padding: 4px 6px;
        font-size: 13px;
        min-height: 26px;
}

QDoubleSpinBox:focus {
        border: 2px solid #2d8cf0;
}

/* 标签样式 */
QLabel {
        font-size: 15px;
        color: #2c3e50;
        font-weight: 500;
        background-color: rgba(255,255,255,0.9);
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #d6e4ff;
}</string>
